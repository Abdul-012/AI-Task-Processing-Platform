# Copy this file to .env for local development.
# Use a long random value, for example: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=1d
FRONTEND_ORIGIN=http://localhost:8080,http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=120
LOG_LEVEL=info

MONGO_URI=mongodb://mongo:27017/ai_tasks
MONGO_DB=ai_tasks
REDIS_URL=redis://redis:6379/0
REDIS_STREAM_KEY=tasks:stream
REDIS_CONSUMER_GROUP=task-workers
REDIS_DEAD_LETTER_STREAM=tasks:dead-letter
